# Example Homebrew formula shape (generated automatically by GoReleaser).
# Published to: https://github.com/LaProgrammerie/homebrew-tap/tree/main/Formula
#
# brew tap LaProgrammerie/tap
# brew install agentflow

class Agentflow < Formula
  desc "Deterministic orchestration for AI coding workflows"
  homepage "https://github.com/LaProgrammerie/hyper-fast-builder"
  version "0.1.0"

  on_macos do
    if Hardware::CPU.arm?
      url "https://github.com/LaProgrammerie/hyper-fast-builder/releases/download/v0.1.0/agentflow_Darwin_arm64.tar.gz"
      sha256 "REPLACE_ME"
    else
      url "https://github.com/LaProgrammerie/hyper-fast-builder/releases/download/v0.1.0/agentflow_Darwin_x86_64.tar.gz"
      sha256 "REPLACE_ME"
    end
  end

  on_linux do
    if Hardware::CPU.arm?
      url "https://github.com/LaProgrammerie/hyper-fast-builder/releases/download/v0.1.0/agentflow_Linux_arm64.tar.gz"
      sha256 "REPLACE_ME"
    else
      url "https://github.com/LaProgrammerie/hyper-fast-builder/releases/download/v0.1.0/agentflow_Linux_x86_64.tar.gz"
      sha256 "REPLACE_ME"
    end
  end

  def install
    bin.install "agentflow"
  end

  test do
    assert_match version.to_s, shell_output("#{bin}/agentflow version")
  end
end
