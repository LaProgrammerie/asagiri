{
  "name": "@laprogrammerie/asagiri",
  "version": "0.1.0",
  "description": "TypeScript client for the local Asagiri runtime API",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LaProgrammerie/hyper-fast-builder.git",
    "directory": "sdk/typescript"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test src/*.test.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
