#!/usr/bin/env bash
set -euo pipefail

COMMIT_MSG_FILE="${1:-}"

if [[ -z "${COMMIT_MSG_FILE}" || ! -f "${COMMIT_MSG_FILE}" ]]; then
    echo "commit-msg: missing commit message file"
    exit 1
fi

FIRST_LINE="$(sed -n '1p' "${COMMIT_MSG_FILE}")"

# Allow Git-generated commit messages and autosquash helpers.
if [[ "${FIRST_LINE}" =~ ^Merge\  ]] || [[ "${FIRST_LINE}" =~ ^Revert\ \" ]] || [[ "${FIRST_LINE}" =~ ^(fixup|squash)!\  ]]; then
    exit 0
fi

# Conventional Commits:
# type(scope)!: subject
# type!: subject
# type: subject
CONVENTIONAL_REGEX='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?(!)?: .+'

if [[ "${FIRST_LINE}" =~ ${CONVENTIONAL_REGEX} ]]; then
    exit 0
fi

echo "Invalid commit message format."
echo "Expected Conventional Commits, examples:"
echo "  feat(blog): add article search"
echo "  fix(auth): handle missing token"
echo "  chore: update QA scripts"
echo "Your first line was:"
echo "  ${FIRST_LINE}"
exit 1
