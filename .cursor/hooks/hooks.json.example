{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "_comment": "Illustrative example — adapt to hooks actually supported by your Cursor version (events, matchers, paths).",
  "version": 1,
  "hooks": [
    {
      "name": "guard-critical-files-before-write",
      "event": "preToolUse",
      "matcher": {
        "tool": "Write"
      },
      "command": "echo \"[hook] If path is critical (.env*, **/secrets/**, prod infra), check AGENTS.md invariants before writing\""
    },
    {
      "name": "lint-or-test-after-write",
      "event": "postToolUse",
      "matcher": {
        "tool": "Write"
      },
      "command": "echo \"[hook] After edit: run targeted lint/test (e.g. .ts file → eslint on that file)\""
    },
    {
      "name": "remind-docs-consistency",
      "event": "postToolUse",
      "matcher": {
        "tool": "Write"
      },
      "command": "echo \"[hook] If docs/ai/* changed: check consistency with context-map.md and AGENTS.md\""
    },
    {
      "name": "enrich-on-tool-failure",
      "event": "postToolUseFailure",
      "matcher": {},
      "command": "echo \"[hook] Log command + cwd + output excerpt for diagnostics\""
    }
  ]
}
